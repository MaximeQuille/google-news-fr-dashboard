# Copy this file to /opt/google-news-fr/.env on the VPS.
# Never commit the real .env file.

APP_DIR=/opt/google-news-fr
REPO_URL=https://github.com/MaximeQuille/google-news-fr-dashboard.git
REPO_BRANCH=main
DB_PATH=/opt/google-news-fr/app/sortie_google_news_fr_ULTRA_CLOUD/google_news_fr_ultra.sqlite
LOG_DIR=/var/log/google-news-fr

# Supabase stays the public data/API backend during the transition.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace_me
SUPABASE_SERVICE_ROLE_KEY=replace_me
ALERT_CRON_SECRET=replace_me

# Gmail SMTP for alert delivery.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=replace_me@gmail.com
SMTP_PASSWORD=replace_me_app_password
SMTP_FROM=replace_me@gmail.com

# GitHub Pages publishing. Use a fine-scoped PAT with repo contents write.
GITHUB_REPOSITORY=MaximeQuille/google-news-fr-dashboard
GITHUB_TOKEN=replace_me_github_pat

# Collection tuning.
COLLECT_MODE=ultra
COLLECT_CONCURRENCY=35
COLLECT_REPAIR_LAST_HOURS=24
SUPABASE_PUSH_RECENT_HOURS=72
ALERT_QUEUE_LIMIT=200
